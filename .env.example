# ==============================================================================
# OpenClaw 环境配置模板 (.env.example)
# ==============================================================================
# 使用方法: cp .env.example .env 并根据需要修改配置

# ─────────────────────────────────────────────────────────────────
# 基础路径配置 (容器化最佳实践：配置种子与状态分离)
# ─────────────────────────────────────────────────────────────────
# 宿主机配置存储路径 (默认: ~/.openclaw，作为初始化种子挂载)
OPENCLAW_CONFIG_DIR=~/.openclaw

# 宿主机工作区路径 (默认: ~/.openclaw/workspace，读写挂载)
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace

# 宿主机自定义技能目录 (默认：~/.openclaw/skills/custom-skills，读写挂载)
OPENCLAW_CUSTOM_SKILLS_DIR=~/skills/custom-skills

# 注意：会话和身份数据持久化在 "openclaw-state" 命名卷中，不再直接受宿主机目录覆盖影响。

# ─────────────────────────────────────────────────────────────────
# 网络服务配置
# ─────────────────────────────────────────────────────────────────
# Gateway 访问端口
OPENCLAW_GATEWAY_PORT=18789

# Bridge 访问端口
OPENCLAW_BRIDGE_PORT=18790

# Gateway 访问 Token (留空则安装时自动生成)
OPENCLAW_GATEWAY_TOKEN=

# Gateway 允许的 Origins (JSON 数组)
OPENCLAW_ALLOWED_ORIGINS='["http://127.0.0.1:18789"]'

# ─────────────────────────────────────────────────────────────────
# 代理与镜像配置
# ─────────────────────────────────────────────────────────────────
# 💡 建议在宿主机 hosts 文件中添加 "127.0.0.1 host.docker.internal" 映射
# 这样可以让本地直连、容器内开发共用同一套代理配置字符串，提升环境一致性。
# 容器访问外网用的代理 (示例: http://host.docker.internal:7897)
HTTP_PROXY=
HTTPS_PROXY=

# ─────────────────────────────────────────────────────────────────
# Claude API 自定义配置
# ─────────────────────────────────────────────────────────────────
# 默认状态下交由内部 Proxy 控制，如需直连第三方 API 网关，请修改此处
ANTHROPIC_AUTH_TOKEN=sk-ece000000000000000000000
ANTHROPIC_BASE_URL=http://host.docker.internal:15721

# 国内镜像加速 (可选，开启后构建速度更快)
# Docker 镜像源 (示例: dockerproxy.cn, docker.m.daocloud.io)
DOCKER_MIRROR=docker.io
# Apt 镜像 (优质镜像: mirrors.ustc.edu.cn, mirrors.tuna.tsinghua.edu.cn)
APT_MIRROR=mirrors.ustc.edu.cn
# NPM 镜像 (推荐: https://registry.npmmirror.com)
NPM_MIRROR=https://registry.npmmirror.com
# Python 镜像 (推荐: https://pypi.tuna.tsinghua.edu.cn/simple)
PYTHON_MIRROR=https://pypi.tuna.tsinghua.edu.cn/simple

# 镜像与构建模式 (Orchestration Mode)
# ─────────────────────────────────────────────────────────────────
# 模式开关：控制是使用预构建镜像还是本地构建
#
# A. 极速模式 (直接使用远程镜像，默认)
COMPOSE_FILE=docker-compose.yml
OPENCLAW_SKIP_BUILD=true
OPENCLAW_IMAGE=ghcr.io/hrygo/openclaw-devkit:latest

# B. 本地构建模式 (基于源码开发，推荐开发者使用)
# COMPOSE_FILE=docker-compose.yml:docker-compose.build.yml
# OPENCLAW_SKIP_BUILD=false
# OPENCLAW_IMAGE=openclaw-devkit

# ─────────────────────────────────────────────────────────────────
# 预构建镜像参考:
# - ghcr.io/hrygo/openclaw-devkit:latest        标准版
# - ghcr.io/hrygo/openclaw-devkit:go            Go 版
# - ghcr.io/hrygo/openclaw-devkit:java          Java 版
# - ghcr.io/hrygo/openclaw-devkit:office        Office 版
# ─────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────
# Git 身份配置 (用于容器内提交代码，防止 Shadow Volume 覆盖)
# ─────────────────────────────────────────────────────────────────
# 设置后启动容器将自动注入全局配置，无需依赖宿主机 .gitconfig
GIT_USER_NAME=OpenClawDev
GIT_USER_EMAIL=dev@openclaw.io

# GitHub Token (OpenClaw 专用身份，建议使用独立账号，权限最小化)
# 用途：容器内 Git 操作（提交、推送、拉取）
# 建议：创建专用 GitHub 账号，仅授予必要仓库的最小权限，不要使用主账号
GITHUB_TOKEN=your_github_token_here

# ─────────────────────────────────────────────────────────────────
# Slack 集成配置 (可选)
# ─────────────────────────────────────────────────────────────────
# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack App Token (xapp-...) - 用于 Socket Mode
SLACK_APP_TOKEN=

# Slack 主要管理员 ID (U0...，可选，极高危操作的审批与权限绑定)
# 作用: 将机器人绑定给指定的超级管理员，仅他可审批敏感操作。获取方式：在 Slack 点击你的个人头像 -> 复制 Member ID。
SLACK_PRIMARY_OWNER=

# 机器人在群组中的响应模式 (可选: open | mention | multibot)
# 作用: 
#   - open (默认): 被动应答所有消息，适合纯净专用频道。
#   - mention: 只响应包含 @机器人 的消息，适合多人混合频道，防误触发。
SLACK_GROUP_POLICY=mention

# 频道白名单绑定 (可选，以逗号分隔的频道 ID 列表)
# 作用: 限制机器人只能在特定的频道内被使用。例如：C12345678,C87654321
SLACK_ALLOWED_CHANNELS=

# 身份标识补充 (用于 docker-entrypoint.sh 自动配置)
GIT_USER_NAME=OpenClawDev
GIT_USER_EMAIL=dev@openclaw.io

